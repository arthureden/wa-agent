# ──────────────────────────────────────────────────────────────
# wa-agent — variáveis de ambiente
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env no repositório
# ──────────────────────────────────────────────────────────────

# Obtido em: developers.facebook.com → seu app → WhatsApp → API Setup → Step 1
WA_PHONE_NUMBER_ID=

# Token permanente gerado via System User no Meta Business Manager
# Escopos necessários: whatsapp_business_messaging, whatsapp_business_management
WA_ACCESS_TOKEN=

# Token livre que você escolhe — usado para verificar o webhook na Meta
# Configure o mesmo valor no painel: WhatsApp → Configuration → Verify Token
WA_VERIFY_TOKEN=meu_verify_token_secreto

# Porta do servidor (padrão: 8080)
PORT=8080
